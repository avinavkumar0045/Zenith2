# Normalize line endings to LF for cross-platform compatibility
* text=auto eol=lf

# Explicitly declare files that should always have LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Denote binary files (so git doesn't try to change line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
